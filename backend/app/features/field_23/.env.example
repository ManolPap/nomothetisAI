# Field 23 — environment variables (copy to project root `.env` or export in shell)
# The backend loads `.env` from the working directory via python-dotenv where configured.

# -----------------------------------------------------------------------------
# Required for: compare-laws (embedding similarity), attribute-legislative-comments
# -----------------------------------------------------------------------------
GOOGLE_API_KEY=

# -----------------------------------------------------------------------------
# Optional — legislative comment attribution (Gemini chat)
# Default if unset: gemini-2.0-flash
# -----------------------------------------------------------------------------
# FIELD_23_COMMENT_ATTRIBUTION_MODEL=gemini-2.0-flash

# -----------------------------------------------------------------------------
# Optional — on-disk cache for LLM / embeddings (diskcache)
# Default: ~/.cache/legal_analyzer/llm_cache
# -----------------------------------------------------------------------------
# LEGAL_ANALYZER_CACHE_DIR=/path/to/cache
