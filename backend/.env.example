# JSON list of frontend origins allowed to call the API.
APP_CORS_ORIGINS=["http://localhost:5173"]

# local | dev | staging | prod
APP_ENV=local

# Required by Field 4 OpenAI analysis.
FEATURE_FIELD_4_OPENAI_MODEL=gpt-4.1
FEATURE_FIELD_4_OPENAI_API_KEY=your-openai-api-key

# FEATURE_ prefix is used to distinguish feature-level settings from app-level settings.
# Required by Field 23 compare/attribution flows.
FEATURE_FIELD_23_GOOGLE_API_KEY=your-google-api-key
FEATURE_FIELD_23_COMMENT_ATTRIBUTION_MODEL=gemini-2.0-flash

# Required by Field 6 (web search + Eurostat) and Field 9 (sector extraction + indicators).
FEATURE_FIELD_6_9_GOOGLE_API_KEY=your-google-api-key
FEATURE_FIELD_6_9_TAVILY_API_KEY=your-tavily-api-key

# Optional override for on-disk LLM cache directory.
# FEATURE_FIELD_23_LEGAL_ANALYZER_CACHE_DIR=/absolute/path/to/cache
